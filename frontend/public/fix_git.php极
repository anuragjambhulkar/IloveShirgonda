<?php
// PHP Script to fix cPanel Git synchronization issues
// Visit this file in your browser to force-reset the Git state on the server.

$repo_path = "/home/iloveshr/ILS"; // Path from your screenshot

echo "<h1>cPanel Git Fixer</h1>";

function run($cmd) {
    global $repo_path;
    echo "<b>Running: $cmd</b><br>";
    echo "<pre>";
    passthru("cd $repo_path && $cmd 2>&1");
    echo "</pre><hr>";
}

run("git status");

echo "<h2>Force Resetting to origin/main (CLEANING SERVER)...</h2>";
run("git fetch origin main");
run("git clean -fd"); // Remove untracked files
run("git reset --hard origin/main"); // Force match GitHub

echo "<h2>Final Status:</h2>";
run("git status");

echo "<h3>DONE! Now go back to cPanel 'Git Version Control' page, REFRESH (F5), and you should see the Deploy button enabled.</h3>";
?>
